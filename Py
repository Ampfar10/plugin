import os
import smtplib
from email.mime.text import MIMEText
from dotenv import load_dotenv
from datetime import datetime

# Load env vars
load_dotenv()

EMAIL = os.getenv("EMAIL_USER")
APP_PASSWORD = os.getenv("EMAIL_PASS")

TO_EMAIL = EMAIL  # send to yourself

def send_styled_email():
    if not EMAIL or not APP_PASSWORD:
        print("❌ Missing EMAIL_USER or EMAIL_PASS")
        return

    # HTML DESIGN (clean + professional)
    html_content = f"""
    <html>
    <body style="font-family: Arial, sans-serif; background-color: #f4f6f8; padding: 20px;">
        <div style="max-width: 600px; margin: auto; background: white; border-radius: 10px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
            
            <h2 style="color: #2ecc71;">✅ Site Back Online</h2>
            
            <p style="font-size: 16px; color: #333;">
                Good news! Your monitored site is back up and running.
            </p>

            <div style="background: #ecf9f1; padding: 15px; border-radius: 8px; margin: 20px 0;">
                <strong>URL:</strong> https://example.com <br>
                <strong>Status:</strong> <span style="color: green;">UP</span><br>
                <strong>Time:</strong> {datetime.utcnow()}
            </div>

            <p style="font-size: 14px; color: #555;">
                Your service is now operating normally again.
            </p>

            <hr style="margin: 20px 0;">

            <p style="font-size: 12px; color: #999;">
                Uptime Tracker API • Monitoring Service
            </p>
        </div>
    </body>
    </html>
    """

    msg = MIMEText(html_content, "html")
    msg["Subject"] = "✅ Site Back Up - Uptime Tracker"
    msg["From"] = EMAIL
    msg["To"] = TO_EMAIL

    try:
        with smtplib.SMTP_SSL("smtp.gmail.com", 465) as server:
            server.login(EMAIL, APP_PASSWORD)
            server.send_message(msg)

        print("✅ Styled email sent successfully!")

    except Exception as e:
        print("❌ Failed:", e)


if __name__ == "__main__":
    send_styled_email()
